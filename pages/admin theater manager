$message = "";

// 1. Handle POST Requests (Add / Edit / Deactivate)
if ($_SERVER["REQUEST_METHOD"] == "POST") {
    $action = $_POST['action'];
    $theaterName = $_POST['theater_name'] ?? '';
    $address = $_POST['address'] ?? '';
    $status = $_POST['status'] ?? 'Active';
    $theaterId = $_POST['theater_id'] ?? null;

    if ($action == 'save') {
        if ($theaterId) {
            // EDIT: Update existing theater
            // SQL: UPDATE theaters SET name=?, address=?, status=? WHERE id=?
            $message = "Theater '$theaterName' updated successfully!";
        } else {
            // ADD: Create new theater
            // SQL: INSERT INTO theaters (name, address, status) VALUES (?, ?, 'Active')
            $message = "Theater '$theaterName' added to the system!";
        }
    } elseif ($action == 'deactivate') {
        // DEACTIVATE: Soft delete by changing status to 'Inactive'
        // SQL: UPDATE theaters SET status='Inactive' WHERE id=?
        $message = "Theater has been deactivated and removed from selection.";
    }
}

